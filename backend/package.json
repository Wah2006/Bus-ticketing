{
    "name": "vibecoding-api",
    "version": "1.0.0",
    "description": "VibeCoding - Multi-agency bus ticketing platform API",
    "type": "module",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "migrate": "node src/shared/db/migrate.js",
        "migrate:rollback": "node src/shared/db/rollback.js",
        "seed": "node src/shared/db/seed.js",
        "lint": "eslint src/ --fix",
        "format": "prettier --write \"src/**/*.js\""
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.1.2",
        "pg": "^8.11.2",
        "redis": "^4.6.12",
        "joi": "^17.11.0",
        "axios": "^1.6.2"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "supertest": "^6.3.3",
        "nodemon": "^3.0.1",
        "eslint": "^8.54.0",
        "prettier": "^3.1.0"
    },
    "keywords": [
        "bus",
        "ticketing",
        "booking",
        "platform",
        "cameroon"
    ],
    "author": "VibeCoding Team",
    "license": "Proprietary"
}